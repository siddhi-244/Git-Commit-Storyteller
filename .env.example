# Required: Your Groq API key (get one at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Application name (default: Git Commit StoryTeller)
APP_NAME=Git Commit StoryTeller

# Optional: Groq model to use (default: llama3-8b-8192)
MODEL=llama3-8b-8192

# Optional: Maximum tokens for AI response (default: 1024)
MAX_TOKENS=1024
